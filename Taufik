    drawWindmill(950, 320);
    for (int i = 0; i < 10; i++) {
        drawTree(150 + i * 120, 320 + (i%3)*10, i);
    }

    float houseY = 285.0f, gap = 210.0f;
    drawModernHouse(    80,         houseY);
    drawTraditionalHouse(80 + gap,  houseY);
    drawFarmHouse(      80 + 2*gap, houseY);
    drawTraditionalHouse(80 + 3*gap,houseY);
    drawModernHouse(    80 + 4*gap, houseY);
    drawFarmHouse(      80 + 5*gap, houseY);

    drawFootpath();
    drawRoad();

    drawBusStop();
    drawTrafficLight();
    drawPlayground();

    for (int i = 0; i < 4; i++)
        drawStreetLight(180 + i * 320, 280);

    drawMovingCar();
    drawMovingBus();

    drawDockAndFisherman();

    // if (showPlane) drawAirplane();

    drawRain();
}

// ============================================================================
// ANIMATION UPDATE
// ============================================================================

void update(int value) {
    if (!animationPaused) {
        cloudOffset   += 0.4f * windIntensity;
        windmillAngle += 2.5f * windIntensity;
        riverWave     += 0.5f;

        // traffic light
        trafficTimer += 1.0f;
        if (trafficTimer > 10000.0f) trafficTimer = 0.0f;
        int cycle = (int)trafficTimer % 260;
        if      (cycle < 120) trafficState = 0;
        else if (cycle < 160) trafficState = 1;
        else                  trafficState = 2;

        // vehicles (respect red light)
        float curCarX = std::fmod(carPosition, WIDTH + 300.0f) - 150.0f;
        float curBusX = std::fmod(busPosition, WIDTH + 500.0f) - 200.0f;
        bool red     = (trafficState == 0);
        bool carNear = red && (curCarX > 620.0f && curCarX < 690.0f);
        bool busNear = red && (curBusX > 620.0f && curBusX < 690.0f);
        if (!carNear) carPosition += 1.8f;
        if (!busNear) busPosition += 1.5f;

        trainPosition -= 1.6f;

        swingAngle += (swingForward ? 0.4f : -0.4f);
        if (swingAngle >  20.0f) swingForward = false;
        if (swingAngle < -20.0f) swingForward = true;

        if (isRaining) {
            rainOffset += 8.0f;
            if (rainOffset > HEIGHT) rainOffset = 0.0f;
        }

        // wrap-around
        if (cloudOffset > WIDTH + 300) cloudOffset = -300;
        if (carPosition > WIDTH + 250)  carPosition = -250;
        if (busPosition > WIDTH + 400)  busPosition = -400;
        if (trainPosition < -800)       trainPosition = WIDTH + 400;

        windIntensity = windUser;
    }

    glutPostRedisplay();
    glutTimerFunc(16, update, 0);
}

// ============================================================================
// DISPLAY
// ============================================================================

void display() {
    glClear(GL_COLOR_BUFFER_BIT);

    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    gluOrtho2D(0, WIDTH, 0, HEIGHT);
    glMatrixMode(GL_MODELVIEW);
    glLoadIdentity();

    drawVillageScene();

    // HUD bar
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glColor4f(0, 0, 0, 0.45f);
    glBegin(GL_QUADS);
        glVertex2f(0, HEIGHT-60); glVertex2f(WIDTH, HEIGHT-60);
        glVertex2f(WIDTH, HEIGHT); glVertex2f(0, HEIGHT);
    glEnd();
    glDisable(GL_BLEND);

    glColor3f(1, 1, 1);
    char info[350];

    glRasterPos2f(10, HEIGHT - 20);
    sprintf(info,
        "REALISTIC VILLAGE %s | P: Pause/Play | R: Rain ON/OFF | E: Reset | ESC: Exit",
        animationPaused ? "(PAUSED)" : "(RUNNING)");
    for (int i = 0; info[i]; i++) glutBitmapCharacter(GLUT_BITMAP_HELVETICA_12, info[i]);

    glRasterPos2f(10, HEIGHT - 40);
    sprintf(info,
        "G: Train %s | Rain: %s",
        showTrain  ? "ON" : "OFF",
        isRaining  ? "ON" : "OFF",
        windUser);
    for (int i = 0; info[i]; i++) glutBitmapCharacter(GLUT_BITMAP_HELVETICA_12, info[i]);

    glutSwapBuffers();
}

// ============================================================================
// INPUT
// ============================================================================

void keyboard(unsigned char key, int x, int y) {
    switch (key) {
        case 'p': case 'P':
            animationPaused = !animationPaused;
            printf("Animation %s\n", animationPaused ? "Paused" : "Resumed");
            break;

        case 'r': case 'R':
            isRaining = !isRaining;
            printf("Rain %s\n", isRaining ? "ON" : "OFF");
            break;

        case 'g': case 'G':
            showTrain = !showTrain;
            printf("Train %s\n", showTrain ? "ON" : "OFF");
            break;

        case 'e': case 'E':
            cloudOffset   = 0;
            windmillAngle = 0;
            carPosition   = 0;
            busPosition   = -300;
            swingAngle    = 0;
            swingForward  = true;
            rainOffset    = 0;
            trainPosition = WIDTH + 400.0f;
            riverWave     = 0;
            windIntensity = 1.0f;
            windUser      = 1.0f;
            trafficTimer  = 0;
            trafficState  = 0;
            showPlane     = true;
            showTrain     = true;
            showLights    = true;
            isRaining     = false;
            printf("Reset\n");
            break;

        case 27:
            exit(0);
    }
}

void mouse(int button, int state, int x, int y) {
    if (button == GLUT_LEFT_BUTTON && state == GLUT_DOWN)
        animationPaused = !animationPaused;
}

void reshape(int w, int h) {
    glViewport(0, 0, w, h);
}

// ============================================================================
// MAIN
// ============================================================================

int main(int argc, char** argv) {
    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB);
    glutInitWindowSize(WIDTH, HEIGHT);
    glutInitWindowPosition(50, 50);
    glutCreateWindow("Realistic Village Scene");

    printf("Controls: P=Pause  R=Rain  G=Train  E=Reset  ESC=Exit\n");

    glutDisplayFunc(display);
    glutReshapeFunc(reshape);
    glutKeyboardFunc(keyboard);
    glutMouseFunc(mouse);
    glutTimerFunc(0, update, 0);

    initRendering();
    glutMainLoop();
    return 0;
}
