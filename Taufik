// ============================================================================
// RIVER
// ============================================================================

void drawRiver() {
    float topY    = 180.0f;
    float bottomY = 120.0f;

    float waveIntensity = 3.0f + 2.0f * std::sin(riverWave * 0.05f);

    auto getColors = [&](float x,
                         float &topR, float &topG, float &topB,
                         float &botR, float &botG, float &botB)
    {
        float depth = 0.10f + 0.10f * std::sin(x * 0.02f + riverWave * 0.02f);
        topR = 0.28f; topG = 0.52f; topB = 0.97f;
        botR = 0.18f - depth; botG = 0.42f - depth * 0.9f; botB = 0.85f - depth * 0.6f;
    };

    glBegin(GL_QUAD_STRIP);
    for (int xi = 0; xi < WIDTH; xi += 18) {
        float x = (float)xi;
        float w1 = waveIntensity * std::sin(x * 0.03f + riverWave * 0.10f); // upper wave
        float w2 = waveIntensity * std::sin(x * 0.03f + riverWave * 0.10f + 0.55f); // lower wave
        float topR, topG, topB, botR, botG, botB;
        getColors(x, topR, topG, topB, botR, botG, botB);
        glColor3f(topR, topG, topB); glVertex2f(x, topY + w1);
        glColor3f(botR, botG, botB); glVertex2f(x, bottomY + w2);
    }
    // force last vertex at WIDTH
    {
        float x = (float)WIDTH;
        float w1 = waveIntensity * std::sin(x * 0.03f + riverWave * 0.10f);
        float w2 = waveIntensity * std::sin(x * 0.03f + riverWave * 0.10f + 0.55f);
        float topR, topG, topB, botR, botG, botB;
        getColors(x, topR, topG, topB, botR, botG, botB);
        glColor3f(topR, topG, topB); glVertex2f(x, topY + w1);
        glColor3f(botR, botG, botB); glVertex2f(x, bottomY + w2);
    }
    glEnd();

    // River bank (soil strips)
    glColor3f(0.45f, 0.35f, 0.20f);
    glBegin(GL_QUADS);
        glVertex2f(0, topY); glVertex2f(WIDTH, topY);
        glVertex2f(WIDTH, topY + 10); glVertex2f(0, topY + 10);

        glVertex2f(0, bottomY - 10); glVertex2f(WIDTH, bottomY - 10);
        glVertex2f(WIDTH, bottomY); glVertex2f(0, bottomY);
    glEnd();
}

// ============================================================================
// RAIL TRACK
// ============================================================================

void drawRailTrack() {
    float y0 = 335.0f, y1 = 360.0f;

    glBegin(GL_QUADS);
    glColor3f(0.20f, 0.18f, 0.16f); glVertex2f(0, y0); glVertex2f(WIDTH, y0);
    glColor3f(0.28f, 0.25f, 0.22f); glVertex2f(WIDTH, y1); glVertex2f(0, y1);
    glEnd();

    glPointSize(2.0f);
    glBegin(GL_POINTS);
    for (int i = 0; i < 220; i++) {
        float x = (i * 37) % WIDTH;
        float y = y0 + 2 + (i * 19) % (int)(y1 - y0 - 4);
        float c = 0.35f + 0.15f * ((i % 3) * 0.25f);
        glColor3f(c, c, c); glVertex2f(x, y);
    }
    glEnd();

    float sY0 = y0 + 4, sY1 = y1 - 4;
    for (float x = 0; x < WIDTH; x += 42.0f) {
        glColor3f(0.36f, 0.25f, 0.14f);
        glBegin(GL_QUADS);
            glVertex2f(x,      sY0); glVertex2f(x+28, sY0);
            glVertex2f(x+30,   sY1); glVertex2f(x-2,  sY1);
        glEnd();
    }

    float railY1 = 347.0f, railY2 = 354.0f;

    glColor3f(0.10f, 0.10f, 0.10f);
    glLineWidth(6.0f);
    glBegin(GL_LINES);
        glVertex2f(0, railY1-2); glVertex2f(WIDTH, railY1-2);
        glVertex2f(0, railY2-2); glVertex2f(WIDTH, railY2-2);
    glEnd();

    glColor3f(0.55f, 0.55f, 0.58f);
    glLineWidth(4.0f);
    glBegin(GL_LINES);
        glVertex2f(0, railY1); glVertex2f(WIDTH, railY1);
        glVertex2f(0, railY2); glVertex2f(WIDTH, railY2);
    glEnd();

    glColor3f(0.85f, 0.85f, 0.88f);
    glLineWidth(1.5f);
    glBegin(GL_LINES);
        glVertex2f(0, railY1+1); glVertex2f(WIDTH, railY1+1);
        glVertex2f(0, railY2+1); glVertex2f(WIDTH, railY2+1);
    glEnd();

    glColor3f(0.25f, 0.25f, 0.28f);
    for (float x = 8; x < WIDTH; x += 42.0f) {
        glBegin(GL_QUADS);
            glVertex2f(x+6, railY1-3); glVertex2f(x+14, railY1-3);
            glVertex2f(x+14, railY1+3); glVertex2f(x+6, railY1+3);
            glVertex2f(x+6, railY2-3); glVertex2f(x+14, railY2-3);
            glVertex2f(x+14, railY2+3); glVertex2f(x+6, railY2+3);
        glEnd();
        glPointSize(2.0f);
        glBegin(GL_POINTS);
            glVertex2f(x+7, railY1-1); glVertex2f(x+13, railY1-1);
            glVertex2f(x+7, railY2-1); glVertex2f(x+13, railY2-1);
        glEnd();
    }
}

