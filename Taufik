// Static sun in the middle of the sky
void drawSunStatic() {
    float x = WIDTH * 0.5f;
    float y = 590.0f;

    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);

    // glow layers
    for (int i = 3; i > 0; --i) {
        glColor4f(1.0f, 1.0f, 0.5f, 0.10f * i);
        drawCircle(x, y, 30.0f + i * 10.0f);
    }

    // main sun body
    glColor4f(1.0f, 1.0f, 0.0f, 1.0f);
    drawCircle(x, y, 30.0f);

    // rays
    glColor4f(1.0f, 1.0f, 0.5f, 0.55f);
    glLineWidth(2.5f);
    for (int i = 0; i < 16; i++) {
        float ang = 2.0f * M_PI * i / 16.0f;
        float x1 = x + std::cos(ang) * 40.0f, y1 = y + std::sin(ang) * 40.0f;
        float x2 = x + std::cos(ang) * 60.0f, y2 = y + std::sin(ang) * 60.0f;
        glBegin(GL_LINES); glVertex2f(x1, y1); glVertex2f(x2, y2); glEnd();
    }

    glDisable(GL_BLEND);
}

void drawClouds() {
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);

    float speed = 0.5f * windIntensity;

    for (int layer = 0; layer < 3; layer++) {
        float layerSpeed = speed * (layer + 1) * 0.5f;
        float layerY     = 500.0f + layer * 40.0f;
        float layerAlpha = 0.7f - layer * 0.2f;

        glColor4f(1.0f, 1.0f, 1.0f, layerAlpha);

        float c1x = 150.0f + cloudOffset * layerSpeed;
        drawCircle(c1x,      layerY,       25.0f);
        drawCircle(c1x+22,   layerY+12,    22.0f);
        drawCircle(c1x+45,   layerY,       25.0f);
        drawCircle(c1x+22,   layerY-10,    20.0f);

        float c2x = 600.0f + cloudOffset * layerSpeed * 0.8f;
        drawCircle(c2x,      layerY+20,    30.0f);
        drawCircle(c2x+28,   layerY+30,    25.0f);
        drawCircle(c2x+55,   layerY+20,    28.0f);

        float c3x = 1000.0f + cloudOffset * layerSpeed * 0.6f;
        drawCircle(c3x,      layerY-10,    20.0f);
        drawCircle(c3x+20,   layerY,       18.0f);
        drawCircle(c3x+38,   layerY-10,    22.0f);
    }

    glDisable(GL_BLEND);
}

// ============================================================================
// DISTANT HILLS
// ============================================================================

void drawDistantHills() {
    auto drawHillLayer = [&](float baseY, float bottomY,
                             float amp1, float f1,
                             float amp2, float f2,
                             float step,
                             float r, float g, float b)
    {
        glColor3f(r, g, b);
        glBegin(GL_POLYGON);
        glVertex2f(0, bottomY);
        glVertex2f(0, baseY);
        for (float x = 0; x <= WIDTH; x += step) {
            float h = baseY + amp1 * std::sin(x * f1) + amp2 * std::sin(x * f2 + 1.7f);
            glVertex2f(x, h);
        }
        glVertex2f(WIDTH, baseY);
        glVertex2f(WIDTH, bottomY);
        glEnd();
    };

    // 4 layers with distinct greens
    drawHillLayer(465.0f, 400.0f, 35.0f, 0.0065f, 18.0f, 0.0140f, 25.0f, 0.10f, 0.38f, 0.10f);
    drawHillLayer(445.0f, 380.0f, 45.0f, 0.0080f, 22.0f, 0.0180f, 22.0f, 0.08f, 0.34f, 0.08f);
    drawHillLayer(425.0f, 360.0f, 55.0f, 0.0100f, 28.0f, 0.0240f, 18.0f, 0.06f, 0.28f, 0.06f);
    drawHillLayer(405.0f, 350.0f, 28.0f, 0.0180f, 14.0f, 0.0450f, 14.0f, 0.05f, 0.22f, 0.05f);
}

