void drawCircle(float cx, float cy, float r, int segments) {
    glBegin(GL_TRIANGLE_FAN);
    glVertex2f(cx, cy);
    for (int i = 0; i <= segments; i++) {
        float angle = 2.0f * 3.1415926f * i / segments;
        glVertex2f(cx + r * std::cos(angle), cy + r * std::sin(angle));
    }
    glEnd();
}

void drawEllipse(float cx, float cy, float rx, float ry, int segments) {
    glBegin(GL_TRIANGLE_FAN);
    glVertex2f(cx, cy);
    for (int i = 0; i <= segments; i++) {
        float angle = 2.0f * 3.1415926f * i / segments;
        glVertex2f(cx + rx * std::cos(angle), cy + ry * std::sin(angle));
    }
    glEnd();
}

static inline void plotPoint(int x, int y) {
    glVertex2i(x, y);
}

void drawLineDDA(int x1, int y1, int x2, int y2) {
    float xdif = (float)x2 - (float)x1;
    float ydif = (float)y2 - (float)y1;
    int steps = (fabs(xdif) > fabs(ydif)) ? (int)fabs(xdif) : (int)fabs(ydif);

    glBegin(GL_POINTS);
    if (steps == 0) { plotPoint(x1, y1); glEnd(); return; }

    float xinc = xdif / steps;
    float yinc = ydif / steps;
    float x = (float)x1, y = (float)y1;
    for (int i = 0; i <= steps; i++) {
        plotPoint((int)round(x), (int)round(y));
        x += xinc; y += yinc;
    }
    glEnd();
}

void drawLineBresenham(int x1, int y1, int x2, int y2) {
    if (x1 == x2) {
        int ys = (y1 < y2) ? y1 : y2;
        int ye = (y1 < y2) ? y2 : y1;
        glBegin(GL_POINTS);
        for (int y = ys; y <= ye; y++) plotPoint(x1, y);
        glEnd();
        return;
    }
    float m = float(y2 - y1) / float(x2 - x1);

    if (fabs(m) <= 1.0f && x1 > x2) { std::swap(x1, x2); std::swap(y1, y2); }
    if (m > 1.0f && y1 > y2)        { std::swap(x1, x2); std::swap(y1, y2); }
    if (m < -1.0f && y1 < y2)       { std::swap(x1, x2); std::swap(y1, y2); }

    int dx = x2 - x1, dy = y2 - y1;
    m = float(dy) / float(dx);
    int x, y, pk;

    if (m >= 0 && m <= 1) {
        pk = (2 * (y2-y1) - (x2-x1)); x = x1; y = y1;
        glBegin(GL_POINTS);
        for (int i = 0; i <= (x2-x1); i++) {
            plotPoint(x, y);
            if (pk < 0) { x++; pk += 2*(y2-y1); }
            else { x++; y++; pk += 2*(y2-y1) - 2*(x2-x1); }
        }
        glEnd();
    } else if (m > 1) {
        pk = (2*(x2-x1) - (y2-y1)); x = x1; y = y1;
        glBegin(GL_POINTS);
        for (int i = 0; i <= (y2-y1); i++) {
            plotPoint(x, y);
            if (pk < 0) { y++; pk += 2*(x2-x1); }
            else { x++; y++; pk += 2*(x2-x1) - 2*(y2-y1); }
        }
        glEnd();
    } else if (m < 0 && m >= -1) {
        pk = (2*(y1-y2) - (x2-x1)); x = x1; y = y1;
        glBegin(GL_POINTS);
        for (int i = 0; i <= (x2-x1); i++) {
            plotPoint(x, y);
            if (pk < 0) { x++; pk += 2*(y1-y2); }
            else { x++; y--; pk += 2*(y1-y2) - 2*(x2-x1); }
        }
        glEnd();
    } else {
        pk = (2*(x2-x1) - (y1-y2)); x = x1; y = y1;
        glBegin(GL_POINTS);
        for (int i = 0; i <= (y1-y2); i++) {
            plotPoint(x, y);
            if (pk < 0) { y--; pk += 2*(x2-x1); }
            else { x++; y--; pk += 2*(x2-x1) - 2*(y1-y2); }
        }
        glEnd();
    }
}

void drawCircleMidpoint(int cx, int cy, int r) {
    int x = 0, y = r, p = 1 - r;
    auto plot8 = [&](int px, int py) {
        plotPoint(cx+px, cy+py); plotPoint(cx+py, cy+px);
        plotPoint(cx-px, cy+py); plotPoint(cx-py, cy+px);
        plotPoint(cx-px, cy-py); plotPoint(cx-py, cy-px);
        plotPoint(cx+px, cy-py); plotPoint(cx+py, cy-px);
    };
    glBegin(GL_POINTS);
    while (x < y) {
        plot8(x, y);
        if (p < 0) { x++; p += 2*x + 3; }
        else { x++; y--; p += 2*x - 2*y + 5; }
    }
    glEnd();
}

struct Vec2 { float x, y; };

static inline Vec2 translate2D(Vec2 p, float tx, float ty) { p.x += tx; p.y += ty; return p; }
static inline Vec2 scale2D(Vec2 p, float sx, float sy)     { p.x *= sx; p.y *= sy; return p; }
static inline Vec2 rotate2D(Vec2 p, float angle) {
    float rad = angle * (M_PI / 180.0f);
    float nx = p.x*cos(rad) - p.y*sin(rad);
    float ny = p.x*sin(rad) + p.y*cos(rad);
    return {nx, ny};
}
static inline Vec2 reflectX(Vec2 p) { p.y = -p.y; return p; }
static inline Vec2 reflectY(Vec2 p) { p.x = -p.x; return p; }
static inline Vec2 shear2D(Vec2 p, float shx, float shy) {
    return { p.x + shx*p.y, p.y + shy*p.x };
}
static inline Vec2 applyAllTransforms(Vec2 p,
    float sx, float sy, float rotDeg,
    bool doRX, bool doRY, float shx, float shy, float tx, float ty)
{
    p = scale2D(p, sx, sy);
    p = rotate2D(p, rotDeg);
    if (doRX) p = reflectX(p);
    if (doRY) p = reflectY(p);
    p = shear2D(p, shx, shy);
    p = translate2D(p, tx, ty);
    return p;
}

